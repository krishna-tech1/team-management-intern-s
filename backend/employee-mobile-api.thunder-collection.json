  "requests": [
    {
      "id": "req-01",
      "colId": "employee-mobile-backend-v1",
      "folderId": "f-auth",
      "name": "Employee Login",
      "url": "{{baseUrl}}/api/auth/login",
      "method": "POST",
      "sortNum": 1,
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"employee@example.com\",\n  \"password\": \"password123\"\n}"
      },
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" },
        { "type": "json-query", "custom": "$.data.token", "action": "isValue" }
      ]
    },
    {
      "id": "req-02",
      "colId": "employee-mobile-backend-v1",
      "folderId": "f-dashboard",
      "name": "Get Employee Dashboard",
      "url": "{{baseUrl}}/api/employee/dashboard",
      "method": "GET",
      "sortNum": 2,
      "headers": [
        { "name": "Authorization", "value": "Bearer {{employeeToken}}" }
      ],
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" },
        { "type": "json-query", "custom": "$.data.performanceScore", "action": "isValue" },
        { "type": "json-query", "custom": "$.data.assignedTasks", "action": "isValue" }
      ]
    },
    {
