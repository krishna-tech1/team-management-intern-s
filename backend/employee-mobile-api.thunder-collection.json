        "type": "json",
        "raw": "{\n  \"status\": \"ON_HOLD\"\n}"
      }
    },
    {
      "id": "req-10",
      "colId": "employee-mobile-backend-v1",
      "folderId": "f-tasks",
      "name": "Complete Task (→ COMPLETED)",
      "url": "{{baseUrl}}/api/employee/tasks/{{taskId}}/status",
      "method": "PUT",
      "sortNum": 10,
      "headers": [
        { "name": "Authorization", "value": "Bearer {{employeeToken}}" },
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "type": "json",
        "raw": "{\n  \"status\": \"COMPLETED\"\n}"
      }
    },
    {
