        "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
      },
      "tests": [
        { "type": "res-code", "custom": "", "action": "equal", "value": "200" }
      ]
    },
    {
      "id": "req-09",
      "colId": "employee-mobile-backend-v1",
      "folderId": "f-tasks",
      "name": "Pause Task (IN_PROGRESS → ON_HOLD)",
      "url": "{{baseUrl}}/api/employee/tasks/{{taskId}}/status",
      "method": "PUT",
      "sortNum": 9,
      "headers": [
        { "name": "Authorization", "value": "Bearer {{employeeToken}}" },
