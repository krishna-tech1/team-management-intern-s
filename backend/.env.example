# Database Connection URL (e.g., PostgreSQL or Neon DB)
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?sslmode=require"

# JWT Authentication Config
JWT_SECRET="your-very-secure-jwt-secret-key-here"
JWT_EXPIRY="7d"

# Optional App Server Configuration
PORT=4000
NODE_ENV="production"

# Cloudinary Integration (Required for profile photos & document uploads)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
